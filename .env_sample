# ===== SmartHR API =====
SMARTHR_API_BASE_URL=https://{your_subdomain}.smarthr.jp/api
SMARTHR_API_KEY="your_API_KEY"

# ベースURL
# SmartHR API のベースURLは、各テナントのサブドメインに応じて
# https://{your_subdomain}.smarthr.jp/api の形式で指定してください。
# API Key取得方法:
# 1. SmartHRの管理者パネルにログイン
# 2. 開発者設定またはAPI設定セクションに移動
# 3. 新しいAPI Keyを生成
# 4. このファイルの SMARTHR_API_KEY に生成されたキーを貼り付け

# ===== Google OAuth (claude.ai リモートコネクタ用) =====
# Google Cloud Console > APIとサービス > 認証情報 で作成した
# 「OAuth 2.0 クライアント ID (ウェブアプリケーション)」の値
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx

# 公開URL (Cloud Run のサービスURL。末尾スラッシュなし)
# OAuth リダイレクト URI は {PUBLIC_BASE_URL}/auth/callback になる
PUBLIC_BASE_URL=https://your-service-xxxx.a.run.app

# アクセスを許可する Google Workspace ドメイン (カンマ区切り)
ALLOWED_GOOGLE_DOMAINS=innovative-space-carrier.co.jp

# ローカルで認証なしで疎通確認したいときのみ 1 にする (本番では未設定)
# DISABLE_AUTH=1
